   "source": [
    "import tensorflow as tf\n",
    "\n",
    "x = tf.random.uniform((1, 3, 4))  # (batch_size, seq_len, d_model)\n",
    "\n",
    "attention = tf.keras.layers.MultiHeadAttention(\n",
    "    num_heads=4,\n",
    "    key_dim=64\n",
    ")\n",
    "\n",
    "output = attention(query=x, value=x, key=x)\n",
    "\n",
    "output"
