   "metadata": {},
   "outputs": [],
   "source": [
    "model = keras.Sequential([\n",
    "    layers.GRU(64, return_sequences=True),\n",
    "    layers.GRU(32),\n",
    "    layers.Dense(1)\n",
    "])"
   ]
